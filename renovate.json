{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"timezone": "Asia/Tokyo",
	"schedule": ["after 1am and before 5am"],
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 3am"]
	},
	"minimumReleaseAge": "25 hours",
	"rangeStrategy": "replace",
	"vulnerabilityAlerts": {
		"enabled": true,
		"automerge": false
	},
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		}
	]
}
