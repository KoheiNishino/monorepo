{
	"name": "monorepo",
	"type": "module",
	"scripts": {
		"biome": "biome check",
		"biome:write": "pnpm biome --write",
		"clean": "rm -fr node_modules && pnpm -r exec rm -fr node_modules",
		"eslint": "eslint --flag unstable_native_nodejs_ts_config",
		"eslint:fix": "pnpm eslint --fix",
		"eslint:inspector": "pnpm dlx @eslint/config-inspector",
		"tsc": "tsc --noEmit",
		"apps:saas": "pnpm -F saas"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@eslint/compat": "2.0.3",
		"@eslint/js": "9.39.4",
		"@next/eslint-plugin-next": "16.2.0",
		"@tailwindcss/postcss": "4.2.2",
		"@types/node": "24.12.0",
		"eslint": "9.39.4",
		"eslint-plugin-better-tailwindcss": "4.3.2",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"tailwindcss": "4.2.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.1"
	},
	"engines": {
		"node": "24.14.0"
	},
	"packageManager": "pnpm@10.32.1",
	"postcss": {
		"plugins": {
			"@tailwindcss/postcss": {}
		}
	}
}
